# LinChat 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# ========== PostgreSQL 配置 ==========
POSTGRES_USER=postgres
POSTGRES_PASSWORD=linchat_123
# 应用数据库连接 (linchat 库)
DATABASE_URL=postgresql://postgres:linchat_123@localhost:5432/linchat

# ========== Redis 配置 ==========
REDIS_URL=redis://localhost:6379/0

# ========== Langfuse 配置 ==========
LANGFUSE_SECRET=your-nextauth-secret-min-32-chars
LANGFUSE_SALT=your-salt-min-32-chars
LANGFUSE_TELEMETRY=false
# Langfuse API (用于应用集成)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=http://localhost:3000

# ========== vLLM 配置 ==========
# 内网 vLLM 服务地址 (兼容 OpenAI API)
VLLM_API_BASE=http://your-vllm-server:8000/v1
VLLM_API_KEY=your-vllm-api-key
VLLM_MODEL_NAME=your-model-name

# ========== 应用配置 ==========
# Django
DJANGO_SECRET_KEY=your-django-secret-key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 国密加密密钥
SM4_SECRET_KEY=your-sm4-secret-key-16bytes
